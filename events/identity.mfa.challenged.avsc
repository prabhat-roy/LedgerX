{
  "type": "record",
  "namespace": "com.ledgerx.identity.events",
  "name": "MfaChallenged",
  "fields": [
    { "name": "event_id", "type": { "type": "string", "logicalType": "uuid" } },
    { "name": "event_time", "type": { "type": "long", "logicalType": "timestamp-millis" } },
    { "name": "user_id", "type": "string" },
    { "name": "factor", "type": "string", "doc": "TOTP | WEBAUTHN | PUSH | SMS_OTP" },
    { "name": "outcome", "type": "string", "doc": "PASS | FAIL | TIMEOUT" }
  ]
}
