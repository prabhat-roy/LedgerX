# ============================================================
# LedgerX — local development environment.
# Copy to .env and adjust per developer.
# .env is gitignored — never commit real credentials.
# PCI-DSS: never put live cardholder data, real PAN, or
# production keys in here, even temporarily.
# ============================================================

# ----- General -----
ENV=development
LOG_LEVEL=debug
SERVICE_DOMAIN=localhost

# ----- PostgreSQL (operational store) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ledgerx
POSTGRES_PASSWORD=ledgerx
POSTGRES_DB=ledgerx

# ----- CockroachDB (multi-region active-active ledger + accounts) -----
COCKROACH_HOST=localhost
COCKROACH_PORT=26257
COCKROACH_USER=ledgerx
COCKROACH_DB=ledgerx_ledger

# ----- EventStoreDB (append-only ledger event store) -----
EVENTSTORE_URL=esdb://localhost:2113?tls=false

# ----- Cassandra (audit + reconciliation event archive) -----
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_KEYSPACE=ledgerx_audit

# ----- ClickHouse (revenue/profitability/segmentation OLAP) -----
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=ledgerx_analytics

# ----- Redis (sessions, idempotency keys, rate limiting) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Kafka (with Conduktor Gateway for schema + PII masking) -----
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081
CONDUKTOR_GATEWAY=http://localhost:8888

# ----- NATS JetStream (low-latency control plane) -----
NATS_URL=nats://localhost:4222

# ----- Object storage (MinIO) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ledgerx

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=local

# ----- Auth (Keycloak / OIDC) -----
OIDC_ISSUER_URL=http://localhost:8080/realms/ledgerx
OIDC_CLIENT_ID=ledgerx
OIDC_CLIENT_SECRET=change-me

# ----- Vault (HSM-backed KEKs in prod) -----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ----- Feature flags (Unleash) -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=

# ----- Observability backends -----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686

# ----- ISO 20022 / SWIFT sandbox -----
SWIFT_GPI_ENDPOINT=https://sandbox.swift.com/gpi
SEPA_TEST_ENDPOINT=https://sandbox.sepa.eu

# ----- HSM (CloudHSM in prod, SoftHSM locally) -----
HSM_PKCS11_LIB=/usr/lib/softhsm/libsofthsm2.so
HSM_PIN=1234
